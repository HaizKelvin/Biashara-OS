rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitives
    function isSignedIn() { 
      return request.auth != null && request.auth.token.email_verified == true; 
    }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    function isAdmin() { 
      return request.auth != null && request.auth.token.email == 'haizkelvin5@gmail.com' && request.auth.token.email_verified == true; 
    }
    
    function isOwner(businessId) {
      return isSignedIn() && (get(/databases/$(database)/documents/businesses/$(businessId)).data.ownerId == request.auth.uid || isAdmin());
    }
    
    function isMember(businessId) {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/businesses/$(businessId)/users/$(request.auth.uid)) ||
        isAdmin()
      );
    }
    
    function isSelf(businessId, userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Validation Helpers
    function isValidBusiness(data) {
      return data.keys().hasAll(['id', 'name', 'ownerId', 'currency', 'createdAt']) &&
             data.id is string && data.id.size() <= 64 &&
             data.name is string && data.name.size() <= 100 &&
             data.ownerId == request.auth.uid &&
             data.currency == 'KES';
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'businessId', 'role', 'createdAt']) &&
             data.uid == request.auth.uid &&
             data.email is string && data.email.size() <= 100 &&
             data.role in ['owner', 'staff'];
    }

    function isValidSale(data) {
      return data.keys().hasAll(['amount', 'paymentMethod', 'userId', 'timestamp']) &&
             data.amount is number && data.amount > 0 &&
             data.paymentMethod in ['cash', 'mpesa', 'credit'] &&
             (data.userId == request.auth.uid || isAdmin()) &&
             data.timestamp == request.time;
    }

    function isValidExpense(data) {
      return data.keys().hasAll(['amount', 'category', 'userId', 'timestamp']) &&
             data.amount is number && data.amount > 0 &&
             (data.userId == request.auth.uid || isAdmin()) &&
             data.timestamp == request.time;
    }

    function isValidProduct(data) {
      return data.keys().hasAll(['name', 'quantity', 'sellPrice', 'userId', 'createdAt']) &&
             data.name is string && data.name.size() <= 100 &&
             data.quantity is number &&
             data.sellPrice is number && data.sellPrice >= 0 &&
             (data.userId == request.auth.uid || isAdmin()) &&
             data.createdAt == request.time;
    }

    function isValidDebt(data) {
      return data.keys().hasAll(['customerName', 'amount', 'status', 'userId', 'createdAt']) &&
             data.customerName is string && data.customerName.size() <= 100 &&
             data.amount is number && data.amount > 0 &&
             data.status in ['pending', 'paid'] &&
             (data.userId == request.auth.uid || isAdmin());
    }

    function isValidNotification(data) {
      return data.keys().hasAll(['id', 'title', 'message', 'timestamp']) &&
             data.id is string && data.id.size() <= 64 &&
             data.title is string && data.title.size() <= 200 &&
             data.message is string && data.message.size() <= 1000 &&
             data.timestamp == request.time;
    }

    function isValidChatMessage(data) {
      return data.keys().hasAll(['text', 'sender', 'userId', 'createdAt']) &&
             data.text is string && data.text.size() <= 2000 &&
             data.sender in ['user', 'ai'] &&
             data.userId == request.auth.uid &&
             data.createdAt == request.time;
    }

    match /businesses/{businessId}/chat_messages/{messageId} {
      allow read: if isMember(businessId);
      allow create: if isMember(businessId) && isValidChatMessage(incoming());
      allow delete: if isMember(businessId);
    }

    // users collection hardening
    match /users/{userId} {
      allow read: if isSignedIn() && (userId == request.auth.uid || isAdmin());
      allow update: if isSignedIn() && userId == request.auth.uid && 
                   incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'phoneNumber']);
      allow create: if isSignedIn() && userId == request.auth.uid;
    }

    // Global admin access
    match /businesses/{businessId} {
      allow read, write: if isAdmin();
    }
    
    // Collections
    match /businesses/{businessId} {
      // Basic business check
      allow get: if isSignedIn() && (existing().ownerId == request.auth.uid || exists(/databases/$(database)/documents/businesses/$(businessId)/users/$(request.auth.uid)) || isAdmin());
      allow create: if isSignedIn() && isValidBusiness(incoming()) && isValidId(businessId);
      allow update: if isSignedIn() && (existing().ownerId == request.auth.uid || isAdmin()) && 
                      incoming().ownerId == existing().ownerId &&
                      incoming().id == existing().id &&
                      incoming().createdAt == existing().createdAt &&
                      incoming().diff(existing()).affectedKeys().hasOnly(['name', 'currency']);

      match /users/{userId} {
        allow read: if isMember(businessId) || (isSignedIn() && existing().ownerId == request.auth.uid);
        allow create: if isSignedIn() && isValidUser(incoming()) && (userId == request.auth.uid || isAdmin());
        allow update: if (isMember(businessId) || (isSignedIn() && get(/databases/$(database)/documents/businesses/$(businessId)).data.ownerId == request.auth.uid)) && 
                        (userId == request.auth.uid || isAdmin()) &&
                        incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'email']) &&
                        incoming().uid == existing().uid;
        allow delete: if isOwner(businessId) && userId != request.auth.uid;
      }

      match /sales/{saleId} {
        allow read: if isMember(businessId) || (isSignedIn() && get(/databases/$(database)/documents/businesses/$(businessId)).data.ownerId == request.auth.uid);
        allow list: if isMember(businessId) || (isSignedIn() && get(/databases/$(database)/documents/businesses/$(businessId)).data.ownerId == request.auth.uid);
        allow create: if (isMember(businessId) || (isSignedIn() && get(/databases/$(database)/documents/businesses/$(businessId)).data.ownerId == request.auth.uid)) && isValidSale(incoming()) && isValidId(saleId);
        allow update: if false; 
        allow delete: if isOwner(businessId);
      }

      match /expenses/{expenseId} {
        allow read: if isMember(businessId) || (isSignedIn() && get(/databases/$(database)/documents/businesses/$(businessId)).data.ownerId == request.auth.uid);
        allow list: if isMember(businessId) || (isSignedIn() && get(/databases/$(database)/documents/businesses/$(businessId)).data.ownerId == request.auth.uid);
        allow create: if (isMember(businessId) || (isSignedIn() && get(/databases/$(database)/documents/businesses/$(businessId)).data.ownerId == request.auth.uid)) && isValidExpense(incoming()) && isValidId(expenseId);
        allow update: if false;
        allow delete: if isOwner(businessId);
      }

      match /inventory/{productId} {
        allow read: if isMember(businessId) || (isSignedIn() && get(/databases/$(database)/documents/businesses/$(businessId)).data.ownerId == request.auth.uid);
        allow list: if isMember(businessId) || (isSignedIn() && get(/databases/$(database)/documents/businesses/$(businessId)).data.ownerId == request.auth.uid);
        allow create: if (isMember(businessId) || (isSignedIn() && get(/databases/$(database)/documents/businesses/$(businessId)).data.ownerId == request.auth.uid)) && isValidProduct(incoming()) && isValidId(productId);
        allow update: if (isMember(businessId) || (isSignedIn() && get(/databases/$(database)/documents/businesses/$(businessId)).data.ownerId == request.auth.uid)) && isValidProduct(incoming());
        allow delete: if isOwner(businessId);
      }

      match /debts/{debtId} {
        allow read: if isMember(businessId) || (isSignedIn() && get(/databases/$(database)/documents/businesses/$(businessId)).data.ownerId == request.auth.uid);
        allow list: if isMember(businessId) || (isSignedIn() && get(/databases/$(database)/documents/businesses/$(businessId)).data.ownerId == request.auth.uid);
        allow create: if (isMember(businessId) || (isSignedIn() && get(/databases/$(database)/documents/businesses/$(businessId)).data.ownerId == request.auth.uid)) && isValidDebt(incoming()) && isValidId(debtId);
        allow update: if (isMember(businessId) || (isSignedIn() && get(/databases/$(database)/documents/businesses/$(businessId)).data.ownerId == request.auth.uid)) && 
                        incoming().diff(existing()).affectedKeys().hasOnly(['status']) &&
                        existing().status == 'pending';
        allow delete: if isOwner(businessId);
      }

      match /notifications/{notificationId} {
        allow read: if isMember(businessId);
        allow list: if isMember(businessId);
        allow create: if isOwner(businessId) && isValidNotification(incoming()) && isValidId(notificationId);
        allow update: if false;
        allow delete: if isOwner(businessId);
      }
    }
  }
}
